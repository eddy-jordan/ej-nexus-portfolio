---
const skillGroups = [
  {
    title: "Machine Learning",
    accent: "text-violet-glow",
    skills: [
      "Python (Pandas, NumPy, Scikit-learn, PyTorch, XGBoost)",
      "Logistic Regression, Decision Trees, Random Forest, Gradient Boosting",
      "Transfer learning & fine-tuning (ResNet50)",
      "Feature engineering & selection",
      "Model evaluation (Accuracy, Precision, Recall, F1, ROC-AUC)",
      "EDA & data visualization (Matplotlib, Seaborn)",
    ],
  },
  {
    title: "MLOps & Deployment",
    accent: "text-blue-400",
    skills: [
      "Experiment tracking (MLflow)",
      "Docker containerization",
      "FastAPI & Flask APIs",
      "ONNX Runtime model optimization",
      "Data drift detection (Evidently AI)",
      "CI/CD pipelines (GitHub Actions)",
    ],
  },
  {
    title: "Full-Stack Development",
    accent: "text-cyan-glow",
    skills: [
      "Django & Flask (REST API design)",
      "HTMX & Alpine.js",
      "PostgreSQL & SQLite",
      "Model serialization (joblib / pickle)",
      "Deployment (Render, cloud hosting)",
      "Git & GitHub version control",
    ],
  },
  {
    title: "Design & Media",
    accent: "text-emerald-400",
    skills: [
      "Brand identity & logo design",
      "Canva production design",
      "UI layout & motion detailing",
      "Illustration — ink, ballpoint, marker",
      "Composition & figure drawing",
      "Client branding & visual direction",
    ],
  },
];
---

<section id="skills" class="relative px-6 py-24 border-t border-white/5">
  <div class="mx-auto max-w-6xl">
    <p class="font-display text-sm tracking-[0.3em] uppercase text-cyan-glow mb-4">Skills</p>
    <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight mb-12">
      What I work with
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {skillGroups.map((group, i) => (
        <div data-reveal style={`--reveal-delay: ${i * 90}ms`} class="glass rounded-2xl p-6">
          <h3 class={`font-display font-semibold mb-4 ${group.accent}`}>{group.title}</h3>
          <ul class="space-y-2.5">
            {group.skills.map((skill) => (
              <li class="text-sm text-ink-200 flex gap-2.5">
                <span class="text-ink-400 mt-0.5">&#8226;</span>
                <span>{skill}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
