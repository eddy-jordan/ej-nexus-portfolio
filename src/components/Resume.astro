---
const BASE = import.meta.env.BASE_URL;
---

<section id="resume" class="relative px-6 py-24 border-t border-white/5">
  <div data-reveal class="mx-auto max-w-4xl glass rounded-2xl p-10 text-center">
    <p class="font-display text-sm tracking-[0.3em] uppercase text-cyan-glow mb-4">Resume</p>
    <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight mb-4">
      Full CV, formatted
    </h2>
    <p class="text-ink-200 max-w-xl mx-auto mb-8">
      Education, internship experience, technical skills, and project history in one place —
      read it inline or grab the document.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href={`${BASE}resume`}
        class="px-6 py-3 rounded-full font-medium text-sm bg-gradient-to-r from-violet-500 to-cyan-400 text-ink-950 hover:opacity-90 transition-opacity"
      >
        View Resume
      </a>
      <a
        href={`${BASE}resume/Oluwamurewa_Oyetoro_Resume.docx`}
        class="px-6 py-3 rounded-full font-medium text-sm border border-white/15 text-ink-100 hover:bg-white/5 transition-colors"
      >
        Download .docx
      </a>
    </div>
  </div>
</section>
