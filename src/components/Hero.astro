---
const BASE = import.meta.env.BASE_URL;
---

<section id="top" class="relative overflow-hidden pt-40 pb-28 px-6">
  <div class="absolute inset-0 bg-grid [mask-image:radial-gradient(ellipse_60%_60%_at_50%_20%,#000_40%,transparent_100%)]"></div>
  <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[42rem] h-[42rem] rounded-full bg-violet-glow/20 blur-[120px]"></div>
  <div class="absolute top-40 right-0 w-[24rem] h-[24rem] rounded-full bg-cyan-glow/15 blur-[100px]"></div>

  <div class="relative mx-auto max-w-4xl text-center">
    <p class="font-display text-sm tracking-[0.3em] uppercase text-cyan-glow mb-6">
      Machine Learning &middot; Full-Stack &middot; Design &middot; Art
    </p>

    <h1 class="font-display font-semibold text-4xl sm:text-5xl md:text-6xl leading-tight tracking-tight">
      Oluwamurewa <span class="gradient-text">Oyetoro</span>
    </h1>

    <p class="mt-3 text-ink-400 text-sm tracking-wide">
      also known as <span class="text-ink-200 font-medium">Eddy Jordan</span>
    </p>

    <p class="mt-6 text-lg text-ink-200 max-w-2xl mx-auto leading-relaxed">
      I build machine learning systems and ship them end-to-end — from trained model to
      deployed full-stack product — and design the brand and visuals around them. Off the
      keyboard, I draw.
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a
        href="#projects"
        class="px-6 py-3 rounded-full font-medium text-sm bg-gradient-to-r from-violet-500 to-cyan-400 text-ink-950 hover:opacity-90 transition-opacity"
      >
        View Projects
      </a>
      <a
        href="#art"
        class="px-6 py-3 rounded-full font-medium text-sm border border-white/15 text-ink-100 hover:bg-white/5 transition-colors"
      >
        See Artwork
      </a>
      <a
        href={`${BASE}resume/Oluwamurewa_Oyetoro_Resume.docx`}
        class="px-6 py-3 rounded-full font-medium text-sm border border-white/15 text-ink-100 hover:bg-white/5 transition-colors"
      >
        Download Resume
      </a>
    </div>

    <div class="mt-16 grid grid-cols-3 gap-6 max-w-lg mx-auto text-center">
      <div>
        <p class="font-display text-2xl font-semibold gradient-text">99.5%</p>
        <p class="text-xs text-ink-400 mt-1 tracking-wide">model accuracy</p>
      </div>
      <div>
        <p class="font-display text-2xl font-semibold gradient-text">3</p>
        <p class="text-xs text-ink-400 mt-1 tracking-wide">live shipped apps</p>
      </div>
      <div>
        <p class="font-display text-2xl font-semibold gradient-text">11+</p>
        <p class="text-xs text-ink-400 mt-1 tracking-wide">original artworks</p>
      </div>
    </div>
  </div>
</section>
