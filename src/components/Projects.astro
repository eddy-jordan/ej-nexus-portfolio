---
import { projects, categoryLabels, type Category } from "../data/projects";

const filters: { key: Category | "all"; label: string }[] = [
  { key: "all", label: "All" },
  { key: "ml", label: categoryLabels.ml },
  { key: "fullstack", label: categoryLabels.fullstack },
  { key: "design", label: categoryLabels.design },
];
---

<section id="projects" class="relative px-6 py-24 border-t border-white/5">
  <div class="mx-auto max-w-6xl">
    <p class="font-display text-sm tracking-[0.3em] uppercase text-cyan-glow mb-4">Projects</p>
    <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight mb-8">
      Shipped, not just prototyped
    </h2>

    <div class="flex flex-wrap gap-3 mb-10" id="project-filters">
      {filters.map((f) => (
        <button
          type="button"
          data-filter={f.key}
          class:list={[
            "filter-btn px-4 py-2 rounded-full text-sm font-medium border transition-colors",
            f.key === "all"
              ? "bg-white text-ink-950 border-white"
              : "border-white/15 text-ink-200 hover:bg-white/5",
          ]}
        >
          {f.label}
        </button>
      ))}
    </div>

    <div id="project-grid" class="grid md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <article
          class:list={[
            "project-card glass rounded-2xl p-6 flex flex-col",
            project.featured && "md:col-span-2",
          ]}
          data-categories={project.categories.join(",")}
        >
          <div class={`h-1.5 w-16 rounded-full bg-gradient-to-r ${project.accent} mb-5`}></div>

          <div class="flex flex-wrap gap-2 mb-3">
            {project.featured && (
              <span class="text-[11px] uppercase tracking-wide text-ink-950 bg-gradient-to-r from-violet-500 to-cyan-400 rounded-full px-2.5 py-1 font-semibold">
                Featured
              </span>
            )}
            {project.categories.map((c) => (
              <span class="text-[11px] uppercase tracking-wide text-ink-400 border border-white/10 rounded-full px-2.5 py-1">
                {categoryLabels[c]}
              </span>
            ))}
          </div>

          <h3 class="font-display text-xl font-semibold text-white">{project.title}</h3>
          <p class="text-sm text-cyan-glow mt-1">{project.tagline}</p>
          <p class="text-sm text-ink-200 mt-4 leading-relaxed">{project.description}</p>

          <ul class="mt-4 space-y-1.5">
            {project.highlights.map((h) => (
              <li class="text-sm text-ink-400 flex gap-2.5">
                <span class="text-ink-400 mt-0.5">&#8594;</span>
                <span>{h}</span>
              </li>
            ))}
          </ul>

          <div class="flex flex-wrap gap-2 mt-5">
            {project.stack.map((s) => (
              <span class="text-xs text-ink-200 bg-white/5 rounded-md px-2.5 py-1">{s}</span>
            ))}
          </div>

          {(project.liveUrl || project.demos || project.repoUrl) && (
            <div class="flex flex-wrap gap-3 mt-6 pt-5 border-t border-white/5">
              {project.liveUrl && (
                <a
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-medium px-4 py-2 rounded-full bg-gradient-to-r from-violet-500 to-cyan-400 text-ink-950 hover:opacity-90 transition-opacity"
                >
                  Live Demo
                </a>
              )}
              {project.demos?.map((demo) => (
                <a
                  href={demo.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-medium px-4 py-2 rounded-full bg-gradient-to-r from-violet-500 to-cyan-400 text-ink-950 hover:opacity-90 transition-opacity"
                >
                  {demo.label}
                </a>
              ))}
              {project.repoUrl && (
                <a
                  href={project.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-medium px-4 py-2 rounded-full border border-white/15 text-ink-100 hover:bg-white/5 transition-colors"
                >
                  Source Code
                </a>
              )}
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>("#project-filters .filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(".project-card");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;

      buttons.forEach((b) => {
        b.classList.remove("bg-white", "text-ink-950", "border-white");
        b.classList.add("border-white/15", "text-ink-200");
      });
      btn.classList.add("bg-white", "text-ink-950", "border-white");
      btn.classList.remove("border-white/15", "text-ink-200");

      cards.forEach((card) => {
        const categories = card.dataset.categories?.split(",") ?? [];
        const show = filter === "all" || categories.includes(filter ?? "");
        card.style.display = show ? "" : "none";
      });
    });
  });
</script>
