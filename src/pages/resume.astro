---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const BASE = import.meta.env.BASE_URL;

const skills = {
  "ML / Data": ["Python", "PyTorch", "Scikit-learn", "XGBoost", "Pandas"],
  "MLOps / Deployment": [
    "MLflow",
    "Docker",
    "FastAPI",
    "Flask",
    "Streamlit",
    "GitHub Actions",
    "ONNX",
    "Evidently AI",
  ],
  "Web / Tools": ["Django", "Git", "REST APIs", "PostgreSQL", "Render"],
};

const additionalProjects = [
  {
    title: "Diabetes Risk Prediction",
    detail: "Random Forest classifier (99.5% accuracy); deployed as a live Flask web app on Render.",
  },
  {
    title: "Loan Approval Prediction",
    detail: "Random Forest classifier (83.7% accuracy) with a built-in explainability feature, built in Streamlit.",
  },
  {
    title: "House Price Prediction",
    detail: "XGBoost regression (R² 0.90) with a 79-feature preprocessing pipeline; 33% RMSE improvement through regularization.",
  },
];
---

<Layout title="Resume — Oluwamurewa Oyetoro" description="Resume of Oluwamurewa Oyetoro (Eddy Jordan) — Machine Learning Engineer & Full-Stack Developer.">
  <Header />
  <main class="pt-32 pb-24 px-6">
    <div class="mx-auto max-w-3xl">
      <div class="flex flex-wrap items-center justify-between gap-4 mb-10">
        <div>
          <h1 class="font-display text-3xl font-semibold tracking-tight">Oluwamurewa Abidoye Oyetoro</h1>
          <p class="text-cyan-glow text-sm mt-1">Machine Learning Engineer</p>
        </div>
        <a
          href={`${BASE}resume/Oluwamurewa_Oyetoro_Resume.docx`}
          class="px-5 py-2.5 rounded-full font-medium text-sm bg-gradient-to-r from-violet-500 to-cyan-400 text-ink-950 hover:opacity-90 transition-opacity whitespace-nowrap"
        >
          Download .docx
        </a>
      </div>

      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-ink-400 mb-12 pb-8 border-b border-white/10">
        <span>Accra, Ghana</span>
        <a href="mailto:oyetoroedward@gmail.com" class="hover:text-white transition-colors">oyetoroedward@gmail.com</a>
        <span>+233 50 411 6004</span>
        <span>+234 704 550 4351</span>
        <a href="https://linkedin.com/in/murewa-oyetoro-74367b296" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
          linkedin.com/in/murewa-oyetoro
        </a>
      </div>

      <section class="mb-12">
        <h2 class="font-display text-xl font-semibold text-white mb-3">Summary</h2>
        <p class="text-ink-200 leading-relaxed">
          Machine Learning Engineer with hands-on experience building and deploying
          end-to-end ML systems, from leakage-safe data pipelines to production APIs with
          automated CI/CD. Background spans web development, cybersecurity, and
          client-facing software delivery.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="font-display text-xl font-semibold text-white mb-4">Skills</h2>
        <div class="grid sm:grid-cols-3 gap-6">
          {Object.entries(skills).map(([group, items]) => (
            <div>
              <p class="font-medium text-cyan-glow text-sm mb-2">{group}</p>
              <ul class="space-y-1.5">
                {items.map((item) => (
                  <li class="text-sm text-ink-200 flex gap-2.5">
                    <span class="text-ink-400 mt-0.5">&#8226;</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="font-display text-xl font-semibold text-white mb-4">Featured Project</h2>
        <div>
          <p class="font-medium text-ink-100">MLOps Portfolio: Credit Risk &amp; Medical Imaging Systems</p>
          <p class="text-sm text-ink-400 mb-2">
            github.com/eddy-jordan/jobkaton &middot; Live: jobkaton.onrender.com (credit risk), pneumonia-api-ffo7.onrender.com (X-ray)
          </p>
          <ul class="space-y-1.5">
            <li class="text-sm text-ink-200 flex gap-2.5"><span class="text-ink-400 mt-0.5">&#8226;</span><span>Built a leakage-safe data preprocessing pipeline (scikit-learn) and tracked 12 model training runs in MLflow, selecting a Gradient Boosting classifier reaching 93.4% accuracy and 0.949 AUC-ROC</span></li>
            <li class="text-sm text-ink-200 flex gap-2.5"><span class="text-ink-400 mt-0.5">&#8226;</span><span>Fine-tuned a ResNet50 (PyTorch transfer learning) for pneumonia detection from chest X-rays, achieving 95% recall; applied early stopping and LR scheduling to prevent overfitting</span></li>
            <li class="text-sm text-ink-200 flex gap-2.5"><span class="text-ink-400 mt-0.5">&#8226;</span><span>Converted the model to ONNX Runtime, cutting inference latency 72.9% (366ms &rarr; 99ms) with no loss in prediction accuracy</span></li>
            <li class="text-sm text-ink-200 flex gap-2.5"><span class="text-ink-400 mt-0.5">&#8226;</span><span>Containerized a FastAPI prediction service with Docker and implemented automated data drift detection with Evidently AI</span></li>
            <li class="text-sm text-ink-200 flex gap-2.5"><span class="text-ink-400 mt-0.5">&#8226;</span><span>Designed a GitHub Actions CI/CD pipeline that retrains, evaluates against the production baseline, and auto-deploys a new model only if it improves — live and self-updating</span></li>
          </ul>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="font-display text-xl font-semibold text-white mb-4">Additional ML Projects</h2>
        <ul class="space-y-3">
          {additionalProjects.map((p) => (
            <li class="text-sm text-ink-200">
              <span class="font-medium text-ink-100">{p.title}:</span> {p.detail}
            </li>
          ))}
        </ul>
        <p class="text-sm text-ink-400 mt-4">
          See the <a href={`${BASE}#projects`} class="text-cyan-glow hover:underline">Projects section</a> for live demos and source code.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="font-display text-xl font-semibold text-white mb-4">Experience</h2>
        <div class="space-y-8">
          <div>
            <p class="font-medium text-ink-100">Freelance Web Developer — Aromallure (client e-commerce platform)</p>
            <p class="text-sm text-ink-400 mb-2">2025</p>
            <ul class="space-y-1.5">
              <li class="text-sm text-ink-200 flex gap-2.5"><span class="text-ink-400 mt-0.5">&#8226;</span><span>Designed and deployed a full-stack Django + HTMX + Alpine.js e-commerce platform for a client, handling real orders via Mobile Money integration</span></li>
              <li class="text-sm text-ink-200 flex gap-2.5"><span class="text-ink-400 mt-0.5">&#8226;</span><span>Built a custom admin dashboard, Cloudinary media pipeline, and automated transactional email system; deployed via Render with a custom domain</span></li>
            </ul>
          </div>
          <div>
            <p class="font-medium text-ink-100">IT Intern, Cyber Defense &amp; Network Monitoring — Nigerian Army Cyber Warfare Command</p>
            <p class="text-sm text-ink-400 mb-2">June 2025 – August 2025</p>
            <ul class="space-y-1.5">
              <li class="text-sm text-ink-200 flex gap-2.5"><span class="text-ink-400 mt-0.5">&#8226;</span><span>Monitored network activity and supported cyber defense operations within a military cybersecurity unit</span></li>
              <li class="text-sm text-ink-200 flex gap-2.5"><span class="text-ink-400 mt-0.5">&#8226;</span><span>Produced technical documentation for security procedures and incident tracking</span></li>
            </ul>
          </div>
        </div>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-4">Education</h2>
        <div>
          <p class="font-medium text-ink-100">BSc Information Technology — Methodist University Ghana, Accra</p>
          <p class="text-sm text-ink-400">Expected 2026</p>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
